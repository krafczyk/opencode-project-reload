{
  "name": "opencode-project-reload",
  "version": "0.1.0",
  "description": "Reload an OpenCode project's server-side context without restarting the shared server",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krafczyk/opencode-project-reload.git"
  },
  "type": "module",
  "files": [
    "dist/tui.js"
  ],
  "exports": {
    "./tui": "./dist/tui.js"
  },
  "engines": {
    "opencode": ">=1.18.3 <=1.18.4"
  },
  "scripts": {
    "build": "bun build src/tui.ts --target=bun --format=esm --outfile=dist/tui.js",
    "test": "bun test test/*.test.ts",
    "test:build": "bun run test/build.ts",
    "test:compat": "bun run test/compat.ts",
    "test:package": "bun test test/package.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.18.3",
    "@opentui/core": "0.4.3",
    "@opentui/keymap": "0.4.3",
    "@opentui/solid": "0.4.3",
    "@types/bun": "1.3.13",
    "@types/node": "24.12.2",
    "typescript": "5.8.2"
  }
}
